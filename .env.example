# =========================================================
# Pannly frontend — .env template.
# Copy to frontend/.env.local for local development.
# (Next.js auto-loads .env.local and gitignores it by default.)
#
# IN PRODUCTION (Coolify / hosted deploy):
#   NEXT_PUBLIC_APP_BASE_URL  → https://pannly.getrevlio.com
#   NEXT_PUBLIC_API_BASE_URL  → https://api.pannly.getrevlio.com (or wherever the FastAPI service is reachable)
#   NEXT_PUBLIC_PLAUSIBLE_DOMAIN → pannly.getrevlio.com
# Anything resolving to localhost in production will silently corrupt
# canonical URLs, OG image URLs, and the sitemap. lib/env.ts will throw
# at build time if NEXT_PUBLIC_APP_BASE_URL is missing in NODE_ENV=production.
# =========================================================

# URLs (dev defaults)
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Analytics — leave blank in dev to disable the Plausible script
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Public-facing pricing (mirrors of backend public_* values)
NEXT_PUBLIC_PRO_PRICE_USD_MONTHLY=15
NEXT_PUBLIC_UNLOCK_PRICE_USD_DEFAULT=3
NEXT_PUBLIC_UNLOCK_PRICE_USD_PREMIUM=5
NEXT_PUBLIC_BUILD_WINDOW_DAYS=30

# Optional — used only by scripts/generate-og-image.mjs (Fal AI image gen).
# Leave blank if you don't regenerate OG images locally.
FAL_API_KEY=
